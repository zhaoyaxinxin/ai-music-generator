DEEPSEEK_API_KEY=your_deepseek_api_key
SUNO_API_KEY=your_suno_api_key

# Optional
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
SUNO_BASE_URL=https://api.sunoapi.org
SUNO_MODEL=V4_5ALL
SUNO_AUTH_MODE=auto
DOUBAO_IMAGE_API_KEY=your_doubao_image_api_key
NETEASE_ACCOUNT_NAME=your_netease_account_name
NETEASE_COOKIE=
NETEASE_COOKIES_PATH=
NETEASE_STORAGE_STATE_PATH=.playwright/netease-storage-state.json
NETEASE_BROWSER_CHANNEL=msedge
NETEASE_HEADLESS=false

# The current Suno docs list callBackUrl as required even if you poll task status.
# Replace this with your own callback endpoint if your account enforces callback validation.
SUNO_CALLBACK_URL=https://example.com/suno-callback
